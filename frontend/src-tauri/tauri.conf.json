{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TW Quant Research",
  "version": "0.2.0",
  "identifier": "io.github.justinyu73.twquantengine",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzMDZENjBFODFENUMwOTEKUldTUndOV0JEdFlHMDZIWGxYRW5WVVU4TjFYbzVjUHBsTnpYOE5UZktRVGRBYXMzUWhrUVJYMUIK",
      "endpoints": [
        "https://api.github.com/repos/justinyu73/tw-quant-research/releases/latest"
      ]
    }
  },
  "build": {
    "frontendDist": "../../outputs/dashboard-preview",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "python3 ../scripts/serve_dashboard_dev.py --port 5173",
    "beforeBuildCommand": "node ../scripts/tauri_build_preview.cjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TW Quant Research",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' http://127.0.0.1:*; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/tqe-sidecar"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Taiwan quantitative research viewer",
    "longDescription": "Local EOD K-line research viewer with explicit user-triggered TWSE local data capture.",
    "createUpdaterArtifacts": true
  }
}