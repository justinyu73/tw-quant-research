{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "TQR desktop shell and its local research sidecar",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/tqe-sidecar",
          "cmd": "tqe-sidecar",
          "sidecar": true,
          "args": []
        }
      ]
    },
    "shell:allow-kill"
  ]
}
